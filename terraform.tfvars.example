network_cidr = "10.0.1.0/24" # optional - default value: 192.168.250.0/24

vm_groups = {
  nextcloud = {
    count          = 2
    base_image     = "./images/debian-13-genericcloud-amd64.qcow2"
    memory         = 6162
    vcpu           = 2
    disk_size      = 30 # GB
    cloudinit_file = "./cloud-init/nextcloud-s3-example.yaml"
    ip_address     = ["10.0.1.2", "10.0.1.3"] # optional
  }  
  
  monitoring = {
      count          = 1
      base_image     = "./images/ubuntu-24.04-minimal-cloudimg-amd64.img"
      memory         = "2048"
      vcpu           = 2
      disk_size      = 20 # GB
      cloudinit_file = "./cloud-init/sys-monitoring-example.yaml"
  }
  
  # Kali qemu VM - no cloud
  kali = {
      count          = 1
      base_image     = "./images/kali-linux-2025.2-qemu-amd64.qcow2"
      memory         = "2048"
      vcpu           = 2
      disk_size      = 80 # GB
      ip_address     = ["10.0.1.4"]
  }

}