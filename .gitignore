# === Terraform & OpenTofu ===

# Local .terraform and .tofu directories
.terraform/
.tofu/

# State files
*.tfstate
*.tfstate.*
*.tofu.tfstate
*.tofu.tfstate.*

# Crash log files
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
*.tofuvars
*.tofuvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock files
.terraform.tfstate.lock.info
.tofu.tfstate.lock.info

# Plan output files
*.tfplan
*.tfplan.json
*.tofuplan
*.tofuplan.json

# CLI configuration files
.terraformrc
terraform.rc
.tofurc
opentofu.rc

# Plugin and provider binaries
.terraform/plugins/
.tofu/plugins/
.terraform/providers/
.tofu/providers/

# Backup files
*.backup
*.old
*.bak

# Debug output
*.log
*.tmp
*.out

# === Editor & IDE files ===

# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/

# macOS
.DS_Store

# Linux
*~

# Windows
Thumbs.db
desktop.ini

